extends layout-ua-login.pug

block content
  #app(class="flex flex-col min-h-screen")

    //- Bandeau institutionnel
    div(class="bg-ua-navy border-b-4 border-ua-blue flex-shrink-0")
      div(class="max-w-6xl mx-auto px-6 py-3 flex items-center justify-between")
        div(class="flex items-center gap-4")
          +ua-logo(40)
          div
            p(class="font-display font-bold text-white text-base uppercase tracking-wide leading-tight") Université des Antilles
            p(class="text-white/60 text-xs italic leading-tight") « Être formés ici, c'est briller partout »

    //- Contenu centré
    main#content(class="flex-1 flex items-center justify-center px-4 py-12" tabindex="-1")
      div(class="w-full max-w-md")

        //- Carte de connexion
        div(class="bg-white rounded-2xl shadow-xl p-10 text-center")

          //- Logo UA dans un cercle
          div(class="w-[140px] h-[140px] rounded-full bg-white border-2 border-slate-200 shadow-md mx-auto mb-6 flex items-center justify-center overflow-hidden p-3")
            img(src="/images/logo_ua.png" alt="Université des Antilles" class="w-full h-full object-contain")

          //- Titre
          h1(class="text-2xl font-bold text-ua-navy tracking-tight mb-3")= messages.api.title

          //- Sous-titre
          p(class="text-base text-slate-600 leading-relaxed mb-8")= messages.api.index

          //- Divider
          div(class="h-px bg-slate-200 mb-8")

          //- Bouton Se connecter
          a(href="/login" class="inline-flex items-center justify-center gap-3 w-full h-12 px-8 rounded-lg bg-ua-navy hover:bg-ua-indigo text-white font-semibold text-base transition-colors shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ua-navy focus-visible:ring-offset-2")
            svg(xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true")
              path(d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4")
              polyline(points="10 17 15 12 10 7")
              line(x1="15" y1="12" x2="3" y2="12")
            span #{messages.api.action.connection}

          //- Note sécurité (footer cadenas)
          div(class="mt-6 flex items-start gap-2 text-xs text-gray-400 text-left")
            svg(class="w-3.5 h-3.5 flex-shrink-0 mt-0.5 text-gray-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true")
              path(stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z")
            p Authentification sécurisée via le portail CAS de l'Université des Antilles.

    //- Pied de page
    footer(class="border-t border-gray-200 bg-white px-6 py-4 flex-shrink-0")
      div(class="max-w-6xl mx-auto flex justify-center text-center text-xs text-gray-400")
        p © #{new Date().getFullYear()} Université des Antilles — Direction des Systèmes d'Information et du Numérique
