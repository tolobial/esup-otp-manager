extends layout-ua-login.pug

block content
  #app(class="flex flex-col min-h-screen")

    //- Bandeau institutionnel
    div(class="bg-ua-navy border-b-4 border-ua-blue flex-shrink-0")
      div(class="max-w-6xl mx-auto px-6 py-3 flex items-center justify-between")
        div(class="flex items-center gap-4")
          +ua-logo(40)
          div
            p(class="font-display font-bold text-white text-base uppercase tracking-wide leading-tight") Université des Antilles
            p(class="text-white/60 text-xs leading-tight") Système d'authentification multi-facteurs

    //- Contenu centré
    main#content(class="flex-1 flex items-center justify-center px-4 py-12" tabindex="-1")
      div(class="w-full max-w-md")

        //- Carte de connexion
        div(class="bg-white border border-gray-200 shadow-sm p-8")

          div(class="text-center mb-8")
            div(class="flex justify-center mb-4")
              div(class="w-16 h-16 bg-ua-navy flex items-center justify-center")
                svg(class="w-8 h-8 text-ua-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true")
                  path(stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z")
            h1(class="font-display font-bold text-2xl text-ua-navy uppercase tracking-wide")= messages.api.title
            p(class="text-gray-500 text-sm mt-2 leading-relaxed")= messages.api.index

          div(class="border-t border-gray-100 mb-6")

          //- Bouton connexion CAS
          a(href="/login" class="w-full flex items-center justify-center gap-3 px-6 py-3.5 bg-ua-navy text-white font-semibold text-sm hover:bg-ua-indigo transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ua-navy focus-visible:ring-offset-2")
            svg(class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true")
              path(stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15M12 9l-3 3m0 0 3 3m-3-3h12.75")
            span #{messages.api.action.connection}

          //- Note sécurité
          div(class="mt-4 flex items-start gap-2 text-xs text-gray-400")
            svg(class="w-3.5 h-3.5 flex-shrink-0 mt-0.5 text-gray-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true")
              path(stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z")
            p Authentification sécurisée via le portail CAS de l'Université des Antilles.

    //- Pied de page
    footer(class="border-t border-gray-200 bg-white px-6 py-4 flex-shrink-0")
      div(class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-gray-400")
        p © #{new Date().getFullYear()} Université des Antilles — Direction des Systèmes d'Information
        p(class="italic") « Être formés ici, c'est briller partout »
