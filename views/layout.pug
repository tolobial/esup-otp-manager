        link(rel='stylesheet', href='/stylesheets/ua-cartes-methodes.css')
        meta(name='viewport', content='width=device-width, initial-scale=1.0')
    body
        block content
        script(src='/js/sweetalert2.all.min.js')
        script(src='/js/jquery.min.js')
