doctype html
html(lang=lang)
    head
        title ESUP OTP Manager
        meta(charset='UTF-8')
        link(rel='stylesheet', type='text/css', href='/stylesheets/material-icons.css')
        //- Materialize + style.css sont importés via legacy-wrapper.css pour
