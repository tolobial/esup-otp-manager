script#admin-dashboard(type='text/x-template').
  <div v-if="messages.api" data-tw class="tw-reset min-h-screen bg-gray-100 flex">

    <input type="checkbox" id="sidebar-toggle" class="hidden">

    <!-- Sidebar rétractable -->
    <aside class="sidebar flex-shrink-0 bg-ua-navy flex flex-col h-screen sticky top-0 transition-all duration-300 z-30 overflow-hidden">

      <!-- Logo -->
      <div class="flex items-center gap-2 px-3 py-3 border-b border-white/10 flex-shrink-0 overflow-hidden">
        <svg viewBox="0 0 44 44" width="28" height="28" class="flex-shrink-0" aria-hidden="true" focusable="false">
          <circle cx="22" cy="22" r="20" fill="white"/>
          <path d="M22 3 A19 19 0 0 1 40 29" fill="none" stroke="#00A0DC" stroke-width="2.5" stroke-linecap="round"/>
          <circle cx="33" cy="19" r="3" fill="#CC5717"/>
          <circle cx="33" cy="26" r="3" fill="#9B1E21"/>
          <text x="17.5" y="27" font-family="'Barlow Condensed',Impact,sans-serif" font-weight="800" font-size="12" fill="#202E56" text-anchor="middle">UA</text>
        </svg>
        <span class="sidebar-label font-display font-bold text-white text-xs uppercase tracking-wide whitespace-nowrap">UA MFA</span>
      </div>

      <!-- Navigation accordéon -->
      <nav class="ua-nav-rail flex-1 py-2 px-2" aria-label="Navigation principale">
        <div class="ua-nav-track" :class="{ 'level-sub': $root.navLevel !== 'root' }">

          <!-- Panneau racine -->
          <div class="ua-nav-panel">
            <a href="#" @click="$root.navigate" name="home" class="ua-nav-item" title="Accueil">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
              <span class="lbl">Accueil</span>
            </a>
            <button type="button" @click="$root.drillInto('preferences')" class="ua-nav-item ua-nav-drill" title="Mes préférences">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75"/></svg>
              <span class="lbl">Mes préférences</span>
              <span class="ua-nav-count">{{$root.activeMethodsCount}}/{{$root.availableMethodsCount}}</span>
              <svg class="ua-nav-arr" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
            </button>
            <button v-if="infos.isManager" type="button" @click="$root.drillInto('manager')" class="ua-nav-item ua-nav-drill" title="Outils manager">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"/></svg>
              <span class="lbl">Outils manager</span>
              <svg class="ua-nav-arr" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
            </button>
            <button v-if="infos.role === 'admin'" type="button" @click="$root.drillInto('admin')" class="ua-nav-item ua-nav-drill" title="Administration">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>
              <span class="lbl">Administration</span>
              <svg class="ua-nav-arr" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
            </button>
          </div>

          <!-- Panneau sous-niveau -->
          <div class="ua-nav-panel">
            <button type="button" @click="$root.drillBack()" class="ua-nav-back">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/></svg>
              <span>Accueil</span>
            </button>

            <template v-if="$root.navLevel === 'preferences'">
              <template v-for="method in methods">
                <a v-if="method.activate && method.authorize" href="#" @click="$root.navigate" :name="method.name" class="ua-nav-item" :title="method.label || method.name">
                  <method-icon :name="method.name" />
                  <span class="lbl">{{method.label || method.name}}</span>
                  <span v-if="user.methods && user.methods[method.name]?.active" class="ua-nav-dot" aria-label="active"></span>
                </a>
              </template>
            </template>

            <template v-if="$root.navLevel === 'manager'">
              <a href="#" @click="$root.navigate" name="stats" class="ua-nav-item" title="Statistiques">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/></svg>
                <span class="lbl">Statistiques</span>
              </a>
              <a href="#" @click="$root.navigate" name="manager" class="ua-nav-item" title="Gestion utilisateurs">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/></svg>
                <span class="lbl">Gestion utilisateurs</span>
              </a>
            </template>

            <template v-if="$root.navLevel === 'admin'">
              <a href="#" @click="$root.navigate" name="admin" class="ua-nav-item active" title="Configuration" aria-current="page">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.24-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.213-1.281Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg>
                <span class="lbl">Configuration</span>
              </a>
            </template>
          </div>

        </div>
      </nav>

      <!-- Bas : identité (B) + barre d'actions langue/quitter -->
      <div class="flex-shrink-0 px-2 pb-2">
        <div class="ua-foot-id">
          <div class="relative flex-shrink-0">
            <div class="w-8 h-8 rounded-full bg-ua-blue flex items-center justify-center">
              <span class="text-ua-navy font-display font-bold text-xs">{{(user.name || user.uid).split(' ').map(w => w[0]).join('').substring(0,2).toUpperCase()}}</span>
            </div>
            <span class="absolute -bottom-0.5 -right-0.5 w-3 h-3 rounded-full border-2 border-ua-navy"
                  :class="{ 'bg-ua-blue': infos.role === 'user', 'bg-ua-orange': infos.role === 'manager', 'bg-ua-crimson': infos.role === 'admin' }"
                  :title="infos.role === 'admin' ? 'Administrateur' : infos.role === 'manager' ? 'Manager' : 'Utilisateur'" aria-hidden="true"></span>
          </div>
          <div class="sidebar-label min-w-0">
            <p class="text-white text-xs font-medium truncate leading-tight">{{user.name || user.uid}}</p>
            <p class="text-white/45 text-[10px] uppercase tracking-wide">{{infos.role === 'admin' ? 'Administrateur' : infos.role === 'manager' ? 'Manager' : 'Utilisateur'}}</p>
          </div>
        </div>
        <div class="ua-foot-actions sidebar-label">
          <div class="flex-1 flex items-center justify-center gap-1.5 text-white/40 text-[11px] font-semibold">
            <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418"/></svg>
            <button type="button" @click="$root.getMessages('fr')" class="transition-colors" :class="$root.infos.lang === 'fr' ? 'text-ua-blue' : 'hover:text-white'">FR</button>
            <span class="text-white/25">·</span>
            <button type="button" @click="$root.getMessages('en')" class="transition-colors" :class="$root.infos.lang === 'en' ? 'text-ua-blue' : 'hover:text-white'">EN</button>
          </div>
          <span class="ua-foot-sep"></span>
          <a href="/logout" class="ua-foot-act out" title="Déconnexion">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9"/></svg>
            <span>Quitter</span>
          </a>
        </div>
      </div>
    </aside>

    <!-- ═════════════════════════════════════════════ -->
    <!-- Zone principale                                -->
    <!-- ═════════════════════════════════════════════ -->
    <div class="flex-1 min-w-0 overflow-y-auto">
      <!-- Bandeau d'annonce de mode (Administrateur) -->
      <div class="bg-ua-crimson/10 border-l-[3px] border-ua-crimson text-ua-navy px-4 py-2.5 flex items-center gap-3 text-sm print:hidden" role="status">
        <svg class="w-5 h-5 flex-shrink-0 text-ua-crimson" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.213-1.281Z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
        </svg>
        <div class="flex-1 min-w-0">
          <p class="font-semibold leading-tight">Mode Administrateur</p>
          <p class="text-xs text-gray-600 leading-tight mt-0.5">Vous configurez ici des paramètres globaux qui s'appliquent à toute l'instance.</p>
        </div>
      </div>
      <div class="p-6 lg:p-8 space-y-6">

        <!-- En-tête page -->
        <div>
          <h2 class="font-display font-bold text-2xl text-ua-navy uppercase tracking-wide">Administration MFA</h2>
          <p class="text-gray-500 text-sm mt-1">Contrôle global des méthodes — modifications appliquées à tous les utilisateurs.</p>
        </div>

        <!-- Liste des méthodes (cartes) -->
        <div class="space-y-3">
          <template v-for="method in methods" :key="method.name">
            <div class="bg-white border border-gray-200 transition-colors"
                 :class="methods[method.name].activate ? 'border-l-[3px] border-l-ua-blue' : 'border-l-[3px] border-l-gray-300'">

              <!-- Header carte méthode -->
              <div class="px-5 py-4 flex items-center justify-between gap-4">
                <div class="flex items-center gap-3 flex-1 min-w-0">
                  <!-- Icône (AJOUT UX : repères visuels par méthode) -->
                  <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center transition-colors"
                       :class="methods[method.name].activate ? 'bg-blue-50' : 'bg-gray-50'">
                    <method-icon :name="method.name" :class="methods[method.name].activate ? 'text-ua-blue' : 'text-gray-400'" />
                  </div>
                  <div class="flex-1 min-w-0">
                    <h4 class="font-semibold text-ua-navy text-sm">{{method.label || method.name}}</h4>
                    <p class="text-xs mt-0.5 flex items-center gap-1.5">
                      <span v-if="methods[method.name].activate" class="text-green-600 font-medium inline-flex items-center gap-1.5">
                        <span class="inline-block w-1.5 h-1.5 bg-green-600"></span>
                        Activée pour tous
                      </span>
                      <span v-else class="text-gray-400 inline-flex items-center gap-1.5">
                        <span class="inline-block w-1.5 h-1.5 bg-gray-300"></span>
                        Désactivée
                      </span>
                    </p>
                  </div>
                </div>

                <!-- Switch global activation -->
                <label class="relative inline-flex items-center cursor-pointer flex-shrink-0">
                  <input v-if="methods[method.name].activate"
                         type="checkbox"
                         @click="deactivate"
                         :name="method.name"
                         checked
                         :aria-label="`Désactiver globalement ${method.label || method.name}`"
                         class="sr-only peer">
                  <input v-else
                         type="checkbox"
                         @click="activate"
                         :name="method.name"
                         :aria-label="`Activer globalement ${method.label || method.name}`"
                         class="sr-only peer">
                  <span class="w-12 h-6 bg-gray-300 peer-checked:bg-ua-blue transition-colors duration-200 inline-block"></span>
                  <span class="absolute top-0.5 left-0.5 w-5 h-5 bg-white transition-transform duration-200 peer-checked:translate-x-6 pointer-events-none"></span>
                </label>
              </div>

              <!-- Sous-section : transports (uniquement pour random_code) -->
              <div v-if="method.name === 'random_code'" class="border-t border-gray-100 px-5 py-3 bg-gray-50">
                <h5 class="text-xs font-semibold text-ua-navy uppercase tracking-wide mb-3">Transports activables</h5>
                <div class="space-y-2.5">
                  <!-- SMS -->
                  <div class="flex items-center justify-between gap-3">
                    <span class="text-sm text-gray-700">{{messages.api.transports.sms}}</span>
                    <label class="relative inline-flex items-center cursor-pointer flex-shrink-0">
                      <input v-if="methods[method.name].transports.includes('sms')"
                             type="checkbox"
                             @click="deactivateTransport(method.name, 'sms')"
                             :name="method.name"
                             checked
                             :aria-label="`Désactiver SMS pour ${method.label}`"
                             class="sr-only peer">
                      <input v-else
                             type="checkbox"
                             @click="activateTransport(method.name, 'sms')"
                             :name="method.name"
                             :aria-label="`Activer SMS pour ${method.label}`"
                             class="sr-only peer">
                      <span class="w-10 h-5 bg-gray-300 peer-checked:bg-ua-blue transition-colors duration-200 inline-block"></span>
                      <span class="absolute top-0.5 left-0.5 w-4 h-4 bg-white transition-transform duration-200 peer-checked:translate-x-5 pointer-events-none"></span>
                    </label>
                  </div>
                  <!-- Mail -->
                  <div class="flex items-center justify-between gap-3">
                    <span class="text-sm text-gray-700">{{messages.api.transports.mail}}</span>
                    <label class="relative inline-flex items-center cursor-pointer flex-shrink-0">
                      <input v-if="methods[method.name].transports.includes('mail')"
                             type="checkbox"
                             @click="deactivateTransport(method.name, 'mail')"
                             :name="method.name"
                             checked
                             :aria-label="`Désactiver email pour ${method.label}`"
                             class="sr-only peer">
                      <input v-else
                             type="checkbox"
                             @click="activateTransport(method.name, 'mail')"
                             :name="method.name"
                             :aria-label="`Activer email pour ${method.label}`"
                             class="sr-only peer">
                      <span class="w-10 h-5 bg-gray-300 peer-checked:bg-ua-blue transition-colors duration-200 inline-block"></span>
                      <span class="absolute top-0.5 left-0.5 w-4 h-4 bg-white transition-transform duration-200 peer-checked:translate-x-5 pointer-events-none"></span>
                    </label>
                  </div>
                </div>
              </div>
            </div>
          </template>
        </div>

      </div>
    </div>
  </div>
