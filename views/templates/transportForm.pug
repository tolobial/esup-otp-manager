script#transport_form(type='text/x-template').
  <div class="bg-white p-4 sm:p-5">
    <div class="flex gap-4 items-start">

      <!-- Icône (SMS ou Email) -->
      <div class="flex-shrink-0 w-12 h-12 flex items-center justify-center bg-gray-50 border border-gray-200">
        <img :src="`images/${transport}.svg`" alt="" class="w-8 h-8">
      </div>

      <!-- Contenu -->
      <div class="flex-1 min-w-0">

        <!-- Transport actuel (badge) -->
        <div v-if="user.transports[transport]" class="mb-3 text-sm flex items-center gap-2 flex-wrap">
          <span class="text-xs text-gray-500 uppercase tracking-wide font-medium">{{messages.api.transports[transport]}} actuel :</span>
          <span class="font-mono text-ua-navy bg-blue-50 px-2 py-0.5 select-all border border-blue-100">{{ user.transports[transport] }}</span>
        </div>

        <!-- Formulaire d'ajout/modification -->
        <form @submit.prevent="testAndSaveTransport(transport)">
          <label :for="`${transport}-input`" class="block text-xs font-medium text-ua-navy uppercase tracking-wide mb-1">
            {{ messages.api.transports[transport] }}
          </label>
          <div class="flex flex-col sm:flex-row gap-2">
            <input :type="inputType"
                   :id="`${transport}-input`"
                   required
                   :pattern="infos.transport_regexes[transport] || null"
                   class="flex-1 px-3 py-2 border border-gray-300 focus:border-ua-blue focus:outline-none focus:ring-2 focus:ring-ua-blue/20 text-sm bg-white">
            <div class="flex gap-2 flex-wrap">
              <!-- Sauver (avec test OTP) -->
              <button type="submit"
                      :title="messages.api.methods.random_code.testAndSaveTransport[transport]"
                      class="inline-flex items-center justify-center gap-1.5 px-4 py-2 bg-ua-navy hover:bg-ua-indigo text-white text-xs font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ua-navy focus-visible:ring-offset-1">
                <span v-if="user.transports[transport]">{{ messages.api.action.modify }}</span>
                <span v-else>{{ messages.api.action.save }}</span>
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                </svg>
              </button>
              <!-- Sauver maintenant (manager only, SANS test OTP) -->
              <button v-if="isManager"
                      type="button"
                      @click="($event.target.closest('form').reportValidity() && saveTransport(transport))"
                      :title="messages.api.methods.random_code.saveTransport[transport]"
                      class="inline-flex items-center justify-center gap-1.5 px-4 py-2 bg-green-600 hover:bg-green-700 text-white text-xs font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-green-600 focus-visible:ring-offset-1">
                <span v-if="user.transports[transport]">{{ messages.api.action.modify_now }}</span>
                <span v-else>{{ messages.api.action.save_now }}</span>
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z"/>
                </svg>
              </button>
            </div>
          </div>
        </form>

        <!-- Supprimer (si un transport est défini) -->
        <button v-if="user.transports[transport]"
                type="button"
                @click="deleteTransport(transport)"
                class="mt-3 inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-ua-crimson hover:bg-red-50 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ua-crimson focus-visible:ring-offset-1">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/>
          </svg>
          <span>{{ messages.api.action.remove }}</span>
        </button>
      </div>
    </div>
  </div>
