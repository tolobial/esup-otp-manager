
script#home-dashboard(type='text/x-template').
  <div v-if="messages.api" data-tw class="tw-reset min-h-screen bg-gray-100 flex">

    <!-- Checkbox caché pour toggle sidebar (CSS-only via :has()) -->
    <input type="checkbox" id="sidebar-toggle" class="hidden">

    <!-- Sidebar rétractable -->
    <aside class="sidebar flex-shrink-0 bg-ua-navy flex flex-col h-screen sticky top-0 transition-all duration-300 z-30 overflow-hidden">

      <!-- Logo -->
      <div class="flex items-center gap-2 px-3 py-3 border-b border-white/10 flex-shrink-0 overflow-hidden">
        <svg viewBox="0 0 44 44" width="28" height="28" class="flex-shrink-0" aria-hidden="true" focusable="false">
          <circle cx="22" cy="22" r="20" fill="white"/>
          <path d="M22 3 A19 19 0 0 1 40 29" fill="none" stroke="#00A0DC" stroke-width="2.5" stroke-linecap="round"/>
          <circle cx="33" cy="19" r="3" fill="#CC5717"/>
          <circle cx="33" cy="26" r="3" fill="#9B1E21"/>
          <text x="17.5" y="27" font-family="'Barlow Condensed',Impact,sans-serif" font-weight="800" font-size="12" fill="#202E56" text-anchor="middle">UA</text>
        </svg>
        <span class="sidebar-label font-display font-bold text-white text-xs uppercase tracking-wide whitespace-nowrap">UA MFA</span>
      </div>

      <!-- Navigation accordéon -->
      <nav class="ua-nav-rail flex-1 py-2 px-2" aria-label="Navigation principale">
        <div class="ua-nav-track" :class="{ 'level-sub': $root.navLevel !== 'root' }">

          <!-- Panneau racine -->
          <div class="ua-nav-panel">
            <a href="#" @click="$root.navigate" name="home" class="ua-nav-item active" title="Accueil">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
              <span class="lbl">Accueil</span>
            </a>
            <button type="button" @click="$root.drillInto('preferences')" class="ua-nav-item ua-nav-drill" title="Mes préférences">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75"/></svg>
              <span class="lbl">Mes préférences</span>
              <span class="ua-nav-count">{{$root.activeMethodsCount}}/{{$root.availableMethodsCount}}</span>
              <svg class="ua-nav-arr" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
            </button>
            <button v-if="infos.isManager" type="button" @click="$root.drillInto('manager')" class="ua-nav-item ua-nav-drill" title="Outils manager">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"/></svg>
              <span class="lbl">Outils manager</span>
              <svg class="ua-nav-arr" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
            </button>
            <button v-if="infos.role === 'admin'" type="button" @click="$root.drillInto('admin')" class="ua-nav-item ua-nav-drill" title="Administration">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>
              <span class="lbl">Administration</span>
              <svg class="ua-nav-arr" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
            </button>
          </div>

          <!-- Panneau sous-niveau -->
          <div class="ua-nav-panel">
            <button type="button" @click="$root.drillBack()" class="ua-nav-back">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/></svg>
              <span>Accueil</span>
            </button>

            <template v-if="$root.navLevel === 'preferences'">
              <template v-for="method in methods">
                <a v-if="method.activate && method.authorize" href="#" @click="$root.navigate" :name="method.name" class="ua-nav-item" :title="method.label || method.name">
                  <method-icon :name="method.name" />
                  <span class="lbl">{{method.label || method.name}}</span>
                  <span v-if="user.methods && user.methods[method.name]?.active" class="ua-nav-dot" aria-label="active"></span>
                </a>
              </template>
            </template>

            <template v-if="$root.navLevel === 'manager'">
              <a href="#" @click="$root.navigate" name="stats" class="ua-nav-item" title="Statistiques">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/></svg>
                <span class="lbl">Statistiques</span>
              </a>
              <a href="#" @click="$root.navigate" name="manager" class="ua-nav-item" title="Gestion utilisateurs">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/></svg>
                <span class="lbl">Gestion utilisateurs</span>
              </a>
            </template>

            <template v-if="$root.navLevel === 'admin'">
              <a href="#" @click="$root.navigate" name="admin" class="ua-nav-item" title="Configuration">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.24-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.213-1.281Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg>
                <span class="lbl">Configuration</span>
              </a>
            </template>
          </div>

        </div>
      </nav>

      <!-- Bas : identité (B) + barre d'actions langue/quitter -->
      <div class="flex-shrink-0 px-2 pb-2">
        <div class="ua-foot-id">
          <div class="relative flex-shrink-0">
            <div class="w-8 h-8 rounded-full bg-ua-blue flex items-center justify-center">
              <span class="text-ua-navy font-display font-bold text-xs">{{(user.name || user.uid).split(' ').map(w => w[0]).join('').substring(0,2).toUpperCase()}}</span>
            </div>
            <span class="absolute -bottom-0.5 -right-0.5 w-3 h-3 rounded-full border-2 border-ua-navy"
                  :class="{ 'bg-ua-blue': infos.role === 'user', 'bg-ua-orange': infos.role === 'manager', 'bg-ua-crimson': infos.role === 'admin' }"
                  :title="infos.role === 'admin' ? 'Administrateur' : infos.role === 'manager' ? 'Manager' : 'Utilisateur'" aria-hidden="true"></span>
          </div>
          <div class="sidebar-label min-w-0">
            <p class="text-white text-xs font-medium truncate leading-tight">{{user.name || user.uid}}</p>
            <p class="text-white/45 text-[10px] uppercase tracking-wide">{{infos.role === 'admin' ? 'Administrateur' : infos.role === 'manager' ? 'Manager' : 'Utilisateur'}}</p>
          </div>
        </div>
        <div class="ua-foot-actions sidebar-label">
          <div class="flex-1 flex items-center justify-center gap-1.5 text-white/40 text-[11px] font-semibold">
            <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418"/></svg>
            <button type="button" @click="$root.getMessages('fr')" class="transition-colors" :class="$root.infos.lang === 'fr' ? 'text-ua-blue' : 'hover:text-white'">FR</button>
            <span class="text-white/25">·</span>
            <button type="button" @click="$root.getMessages('en')" class="transition-colors" :class="$root.infos.lang === 'en' ? 'text-ua-blue' : 'hover:text-white'">EN</button>
          </div>
          <span class="ua-foot-sep"></span>
          <a href="/logout" class="ua-foot-act out" title="Déconnexion">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9"/></svg>
            <span>Quitter</span>
          </a>
        </div>
      </div>
    </aside>

    <!-- Contenu principal -->
    <div class="flex-1 min-w-0 overflow-y-auto">
      <div class="p-6 lg:p-8">

        <!-- En-tête page -->
        <div class="mb-6">
          <h2 class="font-display font-bold text-2xl text-ua-navy uppercase tracking-wide">
            {{messages.api.title}}
          </h2>
          <p class="text-gray-500 text-sm mt-1">
            {{messages.api.home.description}}
          </p>
        </div>

        <!-- Score de sécurité -->
        <div class="bg-white border border-gray-300 shadow-sm p-4 mb-6 flex flex-col sm:flex-row sm:items-center gap-4">
          <div class="flex items-center gap-4">
            <div class="text-center">
              <span class="font-display font-bold text-3xl text-ua-navy leading-none">{{Object.values(user.methods).filter(m => m.active).length}}</span>
              <span class="font-display font-bold text-3xl text-gray-300 leading-none">/{{Object.keys(methods).filter(k => methods[k].activate && methods[k].authorize).length}}</span>
              <p class="text-xs text-gray-400 font-semibold uppercase tracking-wide mt-0.5">{{messages.api.home.methods}}</p>
            </div>
            <div class="w-px h-12 bg-gray-200 hidden sm:block" aria-hidden="true"></div>
            <div class="flex-1 min-w-0" style="min-width: 200px;">
              <div class="flex items-center justify-between mb-1.5">
                <span class="text-sm font-semibold text-ua-navy">Score de sécurité</span>
                <span class="text-xs font-semibold"
                      :class="Object.values(user.methods).filter(m => m.active).length <= 1 ? 'text-ua-crimson' : Object.values(user.methods).filter(m => m.active).length <= 2 ? 'text-ua-orange' : Object.values(user.methods).filter(m => m.active).length <= 4 ? 'text-ua-blue' : 'text-green-600'">
                  {{Object.values(user.methods).filter(m => m.active).length === 0 ? 'Aucune' : Object.values(user.methods).filter(m => m.active).length <= 1 ? 'Faible' : Object.values(user.methods).filter(m => m.active).length <= 2 ? 'Moyen' : Object.values(user.methods).filter(m => m.active).length <= 4 ? 'Bon' : 'Élevé'}}
                </span>
              </div>
              <div class="w-full bg-gray-100 h-1.5">
                <div class="h-1.5 transition-all duration-500"
                     :class="Object.values(user.methods).filter(m => m.active).length <= 1 ? 'bg-ua-crimson' : Object.values(user.methods).filter(m => m.active).length <= 2 ? 'bg-ua-orange' : Object.values(user.methods).filter(m => m.active).length <= 4 ? 'bg-ua-blue' : 'bg-green-500'"
                     :style="{ width: (Object.values(user.methods).filter(m => m.active).length / Math.max(Object.keys(methods).filter(k => methods[k].activate && methods[k].authorize).length, 1) * 100) + '%' }"></div>
              </div>
            </div>
          </div>
          <!-- Conseil contextuel -->
          <div v-if="Object.values(user.methods).filter(m => m.active).length < 2" class="flex items-start gap-2 sm:ml-auto bg-orange-50 border border-ua-orange/20 px-3 py-2 text-xs text-ua-navy max-w-xs">
            <svg class="w-4 h-4 text-ua-orange flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
            <span>Activez au moins 2 méthodes pour garantir un accès de secours.</span>
          </div>
        </div>

        <!-- Sélecteur de vue : grille (gestion) / éventail (vitrine) -->
        <div class="ua-view-switch">
          <button type="button" @click="setHomeView('grid')" :class="{active: homeView === 'grid'}">Grille</button>
          <button type="button" @click="setHomeView('fan')"  :class="{active: homeView === 'fan'}">Éventail</button>
          <button type="button" @click="setHomeView('bento')" :class="{active: homeView === 'bento'}">Bento</button>
        </div>

        <!-- Grille des méthodes : 2 colonnes, cartes rectangulaires -->
        <div v-if="homeView === 'grid'" class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <template v-for="method in methods">
            <div v-if="method.activate && method.authorize"
                 class="bg-white border shadow-md flex flex-row items-stretch transition-all duration-200 hover:shadow-xl hover:-translate-y-0.5 hover:border-ua-blue/50 cursor-pointer"
                 :class="user.methods[method.name]?.active ? 'border-gray-300' : 'border-gray-200 opacity-75 hover:opacity-100'"
                 @click="navigate(method.name)">

              <!-- Icône à gauche -->
              <div class="w-16 flex-shrink-0 flex items-center justify-center"
                   :class="user.methods[method.name]?.active ? 'bg-ua-navy' : 'bg-gray-100'">
                <method-icon :name="method.name" :size="'6'" :class="user.methods[method.name]?.active ? 'text-ua-blue' : 'text-gray-400'" />
              </div>

              <!-- Contenu carte -->
              <div class="flex-1 p-4 flex items-center justify-between gap-3">
                <div class="min-w-0">
                  <h3 class="font-semibold text-ua-navy text-sm leading-tight">{{method.label || method.name}}</h3>
                  <p class="text-gray-500 text-xs mt-0.5 truncate">{{messages.api.home[method.name]}}</p>
                </div>
                <div class="flex items-center gap-3 flex-shrink-0">
                  <!-- Toggle visuel -->
                  <span class="relative inline-flex w-9 h-4 items-center transition-colors duration-200"
                        :class="user.methods[method.name]?.active ? 'bg-ua-blue' : 'bg-gray-300'">
                    <span class="absolute w-3 h-3 bg-white transition-transform duration-200"
                          :class="user.methods[method.name]?.active ? 'translate-x-4.5' : 'translate-x-0.5'"></span>
                  </span>
                  <!-- Badge -->
                  <span class="text-xs font-semibold px-2 py-0.5"
                        :class="user.methods[method.name]?.active
                          ? 'bg-blue-50 text-ua-navy'
                          : 'bg-slate-100 text-slate-500'">
                    {{user.methods[method.name]?.active ? messages.api.home.activated : messages.api.home.deactivated}}
                  </span>
                </div>
              </div>
            </div>
          </template>
        </div>

        <!-- Modèle 2 : éventail vitrine -->
        <div v-else-if="homeView === 'fan'" class="ua-fan-zone">

          <div class="ua-fan-controls">
            <button type="button" class="ua-fan-btn" @click="fanToggleMode">
              {{ fanMode === 'fan' ? 'Aligner par 2' : "Revenir à l'éventail" }}
            </button>
          </div>

          <div class="ua-fan-stage" :class="{pairs: fanMode === 'pairs'}"
               @mouseenter="fanStartIdle" @mouseleave="fanLeave">
            <div class="ua-fan">
              <div v-for="(method, i) in visibleMethods" :key="method.name"
                   class="ua-slot" :style="fanSlotStyle(i)">
                <div class="ua-inner">
                  <span class="ua-spot"></span>
                  <div class="ua-card" :class="'g-' + fanColor(i)" @click="onCardClick(i, method)">
                    <div class="ua-ic"><method-icon :name="method.name" :size="'8'"></method-icon></div>
                    <div class="ua-meta">
                      <h3>{{ method.label || method.name }}</h3>
                      <p>{{ messages.api.home[method.name] }}</p>
                    </div>
                    <span class="ua-badge"
                          :class="{ on: user.methods[method.name] && user.methods[method.name].active }">
                      {{ (user.methods[method.name] && user.methods[method.name].active)
                          ? messages.api.home.activated : messages.api.home.deactivated }}
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="ua-fan-nav">
            <button type="button" @click="fanPrev" aria-label="Précédent">‹</button>
            <span class="ua-fan-dots">
              <button v-for="(method, i) in visibleMethods" :key="'dot-' + method.name"
                      type="button" :class="{ on: fanOff(i) === 0 }"
                      @click="fanGo(i)" :aria-label="method.label || method.name"></button>
            </span>
            <button type="button" @click="fanNext" aria-label="Suivant">›</button>
          </div>

        </div>

        <!-- Modèle 3 : bento (clic = aperçu en modal) -->
        <div v-else-if="homeView === 'bento'" class="grid grid-cols-2 md:grid-cols-4 gap-3" style="grid-auto-rows: 7rem;">
          <div v-for="(method, i) in visibleMethods" :key="method.name"
               class="bg-white border shadow-sm flex flex-col justify-between p-3 cursor-pointer transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5 hover:border-ua-blue/50"
               :class="user.methods[method.name]?.active ? 'border-gray-300' : 'border-gray-200 opacity-75 hover:opacity-100'"
               :style="bentoSpan(i)"
               @click="openBento(method)">
            <div class="flex items-start justify-between">
              <method-icon :name="method.name" :size="'8'" :class="user.methods[method.name]?.active ? 'text-ua-blue' : 'text-gray-400'" />
              <svg class="w-4 h-4 text-gray-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/></svg>
            </div>
            <div>
              <h3 class="font-semibold text-ua-navy text-sm leading-tight">{{method.label || method.name}}</h3>
              <span class="inline-block mt-1 text-xs font-semibold px-2 py-0.5"
                    :class="user.methods[method.name]?.active ? 'bg-blue-50 text-ua-navy' : 'bg-slate-100 text-slate-500'">
                {{user.methods[method.name]?.active ? messages.api.home.activated : messages.api.home.deactivated}}
              </span>
            </div>
          </div>
        </div>

        <!-- Modal aperçu (vue bento) -->
        <div v-if="bentoSelected" class="fixed inset-0 z-50 flex items-center justify-center bg-ua-navy/60 p-4" @click.self="closeBento">
          <div class="bg-white shadow-xl w-full max-w-md p-6 relative">
            <button type="button" class="absolute top-3 right-3 text-gray-400 hover:text-ua-navy transition-colors" @click="closeBento" aria-label="Fermer">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
            </button>
            <div class="flex flex-col items-center text-center">
              <div class="w-16 h-16 flex items-center justify-center mb-3"
                   :class="user.methods[bentoSelected.name]?.active ? 'bg-ua-navy' : 'bg-gray-100'">
                <method-icon :name="bentoSelected.name" :size="'8'" :class="user.methods[bentoSelected.name]?.active ? 'text-ua-blue' : 'text-gray-400'" />
              </div>
              <h3 class="font-display font-bold text-xl text-ua-navy uppercase tracking-wide">{{bentoSelected.label || bentoSelected.name}}</h3>
              <p class="text-gray-500 text-sm mt-1">{{messages.api.home[bentoSelected.name]}}</p>
              <span class="mt-3 text-xs font-semibold px-2 py-0.5"
                    :class="user.methods[bentoSelected.name]?.active ? 'bg-blue-50 text-ua-navy' : 'bg-slate-100 text-slate-500'">
                {{user.methods[bentoSelected.name]?.active ? messages.api.home.activated : messages.api.home.deactivated}}
              </span>
              <button type="button" class="mt-5 w-full bg-ua-blue hover:bg-ua-indigo text-white font-semibold py-2.5 transition-colors" @click="bentoManage">Gérer cette méthode</button>
            </div>
          </div>
        </div>

        <p class="text-gray-400 text-xs mt-4">{{messages.api.home.note}}</p>

        <!-- Dock : tutos d'activation par méthode -->
        <footer class="mt-10 pt-6 border-t border-gray-200 print:hidden">
          <p class="text-center text-xs text-gray-500 mb-1">{{messages.api?.home?.help_methods || "Besoin d'aide pour activer une méthode ?"}}</p>
          <nav class="ua-dock" aria-label="Tutoriels d'activation des méthodes">
            <template v-for="method in methods">
              <a v-if="method.activate && method.authorize"
                 class="ua-dock-icon"
                 :href="$root.tutoLinks[method.name] || '#'"
                 :target="$root.tutoLinks[method.name] ? '_blank' : '_self'"
                 rel="noopener"
                 @mousemove="$root.handleDockHover"
                 @mouseleave="$root.resetDockHover"
                 :aria-label="'Tutoriel : ' + (method.label || method.name)">
                <span class="ua-dock-tip">{{method.label || method.name}}</span>
                <span class="ua-dock-box"><method-icon :name="method.name" :size="'6'" /></span>
                <span class="ua-dock-lbl">{{method.label || method.name}}</span>
              </a>
            </template>
          </nav>
        </footer>
      </div>
    </div>
  </div>
