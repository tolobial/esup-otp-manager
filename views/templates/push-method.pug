script#push-method(type='text/x-template').
  <div class="space-y-5">

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- État 1 : Activation en cours (askActivation = true) -->
    <!-- ═══════════════════════════════════════════════════ -->
    <div v-if="user.methods.push.askActivation" class="space-y-4">

      <!-- Carte principale : étapes d'appairage -->
      <div class="bg-white border border-gray-300 shadow-sm p-5">
        <h4 class="font-display font-bold text-ua-navy text-sm uppercase tracking-wide mb-3">Pairer votre application Esup Auth</h4>

        <ol class="space-y-5 text-sm text-gray-700 list-decimal list-inside marker:text-ua-blue marker:font-semibold">

          <!-- 1. Installer Esup Auth -->
          <li v-html="messages.api.methods.push.esup_Auth_installation_instructions.replace('%ESUP_AUTH%', infos.esup_auth_download_link)"></li>

          <!-- 2. Pairer : deep link (mobile) OU QR code (desktop) -->
          <li v-if="user.methods.push.deepLink && infos.mobile"
              v-html="messages.api.methods.push.deeplink_instructions.replace('%DEEPLINK%', user.methods.push.deepLink)"></li>
          <li v-else>
            <span v-html="messages.api.methods.push.qrcode_instructions"></span>
            <div class="push-qrcode mt-3 inline-flex items-center justify-center bg-white border border-gray-200 p-3" v-html="user.methods.push.qrCode"></div>
          </li>
        </ol>
      </div>

      <!-- Carte fallback : activation manuelle -->
      <div class="bg-gray-50 border border-gray-200 p-4">
        <p class="text-xs font-medium text-ua-navy uppercase tracking-wide mb-2">Activation manuelle (si nécessaire)</p>
        <div class="text-sm text-gray-700"
             v-html='messages.api.methods.push.manual_activation_instructions.join("\n").replace("%UID%", user.uid).replace("%ACTIVATION_CODE%", user.methods.push.activationCode).replace("%API_URL%", user.methods.push.api_url)'></div>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- État 2 : Méthode pairée (askActivation = false)     -->
    <!-- ═══════════════════════════════════════════════════ -->
    <div v-else class="bg-white border border-gray-300 shadow-sm p-5">
      <div class="flex items-center gap-4">
        <div class="flex-shrink-0 w-16 h-16 flex items-center justify-center bg-gray-50 border border-gray-200">
          <img src="images/icon-smartphone.svg" alt="" class="w-10 h-10">
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-xs text-gray-500 uppercase tracking-wide mb-1 font-medium">Appareil pairé</p>
          <p class="font-display font-bold text-ua-navy text-base leading-tight">{{user.methods.push.device.platform}}</p>
          <p class="text-sm text-gray-600">{{user.methods.push.device.manufacturer}}</p>
          <p class="text-sm text-gray-500">{{user.methods.push.device.model}}</p>
        </div>
      </div>
    </div>

    <!-- Badges App Stores (Esup Auth) -->
    <div role="list" lang="fr" class="flex flex-wrap items-center justify-center gap-4 pt-3">
      <a role="listitem" target="_blank" rel="noopener"
         title="Esup Auth — disponible sur Google Play pour Android"
         href="https://play.google.com/store/apps/details?id=org.esupportail.esupAuth"
         class="inline-block hover:opacity-80 transition-opacity">
        <img src="images/play-store.png" alt="Disponible sur Google Play" width="150" class="block">
      </a>
      <a role="listitem" target="_blank" rel="noopener"
         title="Esup Auth — Télécharger dans l'App Store pour iOS"
         href="https://apps.apple.com/fr/app/esup-auth/id1563904941"
         class="inline-block hover:opacity-80 transition-opacity">
        <img src="images/app-store.png" alt="Télécharger dans l'App Store" width="150" class="block">
      </a>
    </div>

  </div>
