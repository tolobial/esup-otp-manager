script#bypass-method(type='text/x-template').
  <div class="space-y-5">

    <!-- Bandeau d'avertissement (codes affichés une seule fois) -->
    <div class="bg-ua-crimson text-white px-4 py-3 flex gap-3" role="alert">
      <svg class="w-5 h-5 flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
      </svg>
      <p class="text-sm leading-relaxed">{{messages.api.methods.bypass.note}}</p>
    </div>

    <!-- KPI : codes disponibles / utilisés -->
    <div class="grid grid-cols-2 gap-4">
      <div class="bg-white border border-gray-200 p-4">
        <p class="text-xs text-gray-500 uppercase tracking-wide font-medium">{{messages.api.methods.bypass.available_codes}}</p>
        <p class="font-display font-bold text-3xl text-ua-navy mt-1 leading-none">{{user.methods.bypass.available_code}}</p>
      </div>
      <div class="bg-white border border-gray-200 p-4">
        <p class="text-xs text-gray-500 uppercase tracking-wide font-medium">{{messages.api.methods.bypass.used_codes}}</p>
        <p class="font-display font-bold text-3xl text-gray-400 mt-1 leading-none">{{user.methods.bypass.used_code}}</p>
      </div>
    </div>

    <!-- Codes générés (visibles uniquement après génération) -->
    <div v-if="user.methods.bypass.codes && user.methods.bypass.codes.length > 0" class="bg-white border border-gray-300">

      <div class="px-4 py-3 border-b border-gray-200 flex items-center justify-between gap-3">
        <h4 class="font-semibold text-ua-navy text-sm">{{messages.api.methods.bypass.generated_codes}}</h4>
        <button type="button"
                @click="window.print()"
                class="inline-flex items-center gap-2 px-3 py-1.5 text-xs font-medium text-ua-navy bg-gray-100 hover:bg-gray-200 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ua-navy focus-visible:ring-offset-1"
                aria-label="Imprimer la liste des codes">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0 1 10.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0 .229 2.523a1.125 1.125 0 0 1-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0 0 21 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 0 0-1.913-.247M6.34 18H5.25A2.25 2.25 0 0 1 3 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 0 1 1.913-.247m10.5 0a48.536 48.536 0 0 0-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5Zm-3 0h.008v.008H15V10.5Z"/>
          </svg>
          <span>Imprimer</span>
        </button>
      </div>

      <!-- Stylesheet d'impression (préservée pour la compat — gère le rendu papier) -->
      <link rel="stylesheet" href="/stylesheets/style-print-bypass-method-codes.css" media="print"/>

      <!-- Grille responsive : 2 / 3 / 4 colonnes selon largeur écran -->
      <ul class="bypass-method-codes grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-px bg-gray-200"
          aria-label="Liste des codes de secours générés">
        <li v-for="code in user.methods.bypass.codes"
            :key="code"
            class="bg-white px-3 py-2.5 font-mono text-sm text-ua-navy text-center select-all tabular-nums">
          {{code}}
        </li>
      </ul>
    </div>

    <!-- Date de dernière génération -->
    <p v-if="user.methods.bypass.generation_date" class="text-xs text-gray-500 italic">
      {{messages.api.methods.bypass.generation_date.replace("%DATE%", generationDateString)}}
    </p>

    <!-- Bouton (re)générer -->
    <div class="flex justify-center pt-2">
      <button type="button"
              @click="generate_bypass"
              class="inline-flex items-center gap-2 px-6 py-3 bg-ua-navy hover:bg-ua-indigo text-white font-semibold text-sm transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ua-navy focus-visible:ring-offset-2">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"/>
        </svg>
        <span>{{messages.api.action.generate_codes}}</span>
      </button>
    </div>

  </div>
