script#webauthn-method(type='text/x-template').
  <div class="space-y-4">

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- État SANS clés enregistrées (AJOUT UX)               -->
    <!-- ═══════════════════════════════════════════════════ -->
    <div v-if="webauthnData.auths.length === 0" class="py-12 text-center border border-dashed border-gray-300 bg-gray-50">
      <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 0 1 21.75 8.25Z"/>
      </svg>
      <p class="text-sm text-gray-500 mb-5" v-html="descriptionMessage"></p>
      <button type="button"
              @click="generateWebauthn()"
              :disabled="registrationInProgress"
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-ua-navy hover:bg-ua-indigo disabled:bg-gray-400 disabled:cursor-not-allowed text-white text-sm font-semibold transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ua-navy focus-visible:ring-offset-2">
        <svg v-if="!registrationInProgress" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
        </svg>
        <svg v-else class="w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"/>
        </svg>
        <span>{{messages.api.action.add}}</span>
      </button>
    </div>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- État AVEC clés enregistrées                          -->
    <!-- ═══════════════════════════════════════════════════ -->
    <div v-else>

      <!-- En-tête : description + bouton ajouter -->
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-3">
        <p class="text-sm text-gray-600" v-html="descriptionMessage"></p>
        <button type="button"
                @click="generateWebauthn()"
                :disabled="registrationInProgress"
                class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-ua-navy hover:bg-ua-indigo disabled:bg-gray-400 disabled:cursor-not-allowed text-white text-sm font-semibold transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ua-navy focus-visible:ring-offset-2 flex-shrink-0">
          <svg v-if="!registrationInProgress" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
          </svg>
          <svg v-else class="w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"/>
          </svg>
          <span>{{messages.api.action.add}}</span>
        </button>
      </div>

      <!-- Liste de clés (1 carte par credential) -->
      <ul id="list-of-authenticators" class="space-y-2" role="list" aria-label="Clés de sécurité enregistrées">
        <li v-for="auth in webauthnData.auths" :key="auth.credentialID"
            class="bg-white border border-gray-200 hover:border-gray-300 transition-colors">
          <div class="flex items-center justify-between gap-3 px-4 py-3 flex-wrap sm:flex-nowrap">

            <!-- Identité de la clé (AJOUT UX : vignette icône) -->
            <div class="flex items-center gap-3 flex-1 min-w-0">
              <div class="flex-shrink-0 w-9 h-9 flex items-center justify-center bg-blue-50 border border-blue-100">
                <svg class="w-5 h-5 text-ua-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 0 1 21.75 8.25Z"/>
                </svg>
              </div>
              <span class="text-sm font-medium text-ua-navy truncate">{{ auth.name }}</span>
            </div>

            <!-- Actions -->
            <div class="flex items-center gap-2 flex-shrink-0">
              <button type="button"
                      @click="renameAuthenticator(auth.credentialID)"
                      :title="messages.api.action.rename"
                      class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-ua-navy bg-gray-100 hover:bg-gray-200 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ua-navy focus-visible:ring-offset-1">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10"/>
                </svg>
                <span class="hidden sm:inline">{{messages.api.action.rename}}</span>
              </button>
              <button type="button"
                      @click="deleteAuthenticator(auth.credentialID)"
                      :title="messages.api.action.remove"
                      class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-ua-crimson hover:bg-red-50 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ua-crimson focus-visible:ring-offset-1">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/>
                </svg>
                <span class="hidden sm:inline">{{messages.api.action.remove}}</span>
              </button>
            </div>
          </div>
        </li>
      </ul>

    </div>

  </div>
