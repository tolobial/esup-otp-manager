# ============================================================
# Development authentication stub
# ============================================================
# WARNING: These variables must NEVER be set in production.
# The application will refuse to start if DEV_AUTH=true
# and NODE_ENV=production.
# ============================================================

# Enable the authentication stub (bypasses CAS/SAML).
# When enabled, GET /login creates a fake session immediately.
# DEV_AUTH=true

# UID of the fake user created by the stub (default: "devuser").
# Add this UID to "admins" or "managers" in esup.json to test
# different roles.
# DEV_UID=devuser
